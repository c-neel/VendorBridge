# ============================================
# VendorBridge AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vendorbridge"

# ---- JWT ----
JWT_SECRET="vendorbridge-super-secret-key-change-in-production"
JWT_REFRESH_SECRET="vendorbridge-refresh-secret-key-change-in-production"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- Gemini AI ----
# Paste your Gemini API key below. If left empty or invalid, AI features will use smart mock responses.
GEMINI_API_KEY=""

# ---- Email (Gmail SMTP) ----
# To use Gmail: Enable 2FA → Generate App Password → Paste below
# If left empty, emails will be logged to console instead.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@vendorbridge.in"

# ---- Server ----
API_PORT=5000
WEB_PORT=3000
API_URL="http://localhost:5000"
WEB_URL="http://localhost:3000"

# ---- File Uploads ----
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# ---- App ----
NODE_ENV="development"
